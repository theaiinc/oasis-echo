{
  "name": "oasis-echo",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "Tiered hybrid voice AI assistant — reflex / coordinator / reasoning",
  "repository": {
    "type": "git",
    "url": "https://github.com/theaiinc/oasis-echo.git"
  },
  "engines": {
    "node": ">=20.10.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --dry",
    "test": "npm run -s build && vitest run",
    "test:watch": "vitest",
    "lint": "eslint 'packages/*/src/**/*.ts' 'packages/*/test/**/*.ts'",
    "server": "npm run server -w @oasis-echo/app",
    "clean": "tsc -b --clean"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  }
}
