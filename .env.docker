# Docker environment overrides for oasis-echo.
# Copy to .env or pass via `docker compose --env-file .env.docker up`.
# Host paths use the compose file's dir as root.

# ── Backend ──────────────────────────────────────────────────────────
# Pick one: ollama (local), anthropic, or openai
OASIS_BACKEND=ollama

# Ollama on the host (reachable via host.docker.internal)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=gemma4:e2b

# The SLM router also runs on the local Ollama
OASIS_ROUTER_BASE_URL=http://host.docker.internal:11434
OASIS_ROUTER_MODEL=gemma4:e2b

# ── TTS ──────────────────────────────────────────────────────────────
# Kokoro runs inside the container (no GPU passthrough needed on Apple Silicon).
OASIS_TTS_BACKEND=kokoro
KOKORO_VOICE=af_heart
KOKORO_DTYPE=q8

# ── STT ──────────────────────────────────────────────────────────────
# Optional phrase file path inside the container.
# Mount a local file and set this to the container path.
# OASIS_STT_PHRASES_FILE=/data/voice-commands.txt

# ── Server ───────────────────────────────────────────────────────────
PORT=9187
OASIS_LOG_LEVEL=info
OASIS_PROFILE=m3pro-18gb
