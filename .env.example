# Pick one backend (required — the server refuses to start without one):
#   anthropic → Claude via Anthropic API
#   ollama    → local model via Ollama (http://localhost:11434)
#   openai    → OpenAI or any OpenAI-compatible endpoint
# OASIS_BACKEND=ollama

# Anthropic (cloud)
# ANTHROPIC_API_KEY=sk-ant-...
# OASIS_MODEL=claude-sonnet-4-6

# Ollama (local). Pull a model first, e.g.:
#   ollama pull gemma4:e2b
# Other good choices: gemma3n:e4b, llama3.2, phi3.5, qwen2.5:3b
# OASIS_BACKEND=ollama
# OLLAMA_MODEL=gemma4:e2b
# OLLAMA_BASE_URL=http://localhost:11434

# OpenAI and OpenAI-compatible endpoints (LM Studio, vLLM, OpenRouter,
# Together, Groq, DeepSeek, Mistral, …). Set OPENAI_BASE_URL to redirect.
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# Local TTS (Kokoro-82M). Recommended for best voice quality.
# OASIS_TTS_BACKEND=kokoro
# KOKORO_VOICE=af_heart
# KOKORO_DTYPE=q8

# STT post-processing
# Custom canonical-phrase list for the fuzzy matcher stage. One phrase
# per line, `#` comments allowed. If unset, a small seed list ships
# with the server.
# OASIS_STT_PHRASES_FILE=./config/voice-commands.txt

# Persistent store for user-taught corrections sent via POST /correction.
# Defaults to ./.oasis-corrections.json in the cwd. Delete the file to
# reset the learned vocabulary.
# OASIS_CORRECTIONS_FILE=./.oasis-corrections.json

# Logging and profile
OASIS_LOG_LEVEL=info
OASIS_PROFILE=m3pro-18gb
